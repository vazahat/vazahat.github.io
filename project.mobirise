    "tut1.html": {
      "settings": {
        "meta_descr": "Animating a 3d model in blender using the riggify and makewalk addon.",
        "title": "Animating using riggify and makewalk in blender",
        "order": 10
      },
      "components": [
        {
          "_styles": {
            "padding-top": "(@paddingTop * 15px)",
            "padding-bottom": "(@paddingBottom * 15px)",
            "& when (@bg-type = 'color')": {
